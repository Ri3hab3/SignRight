{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/forms", "destination": "/forms-index.html" },
    { "source": "/forms/nda", "destination": "/forms-nda.html" },
    { "source": "/forms/residential-lease", "destination": "/forms-residential-lease.html" },
    { "source": "/forms/month-to-month-rental", "destination": "/forms-month-to-month-rental.html" },
    { "source": "/forms/rental-application", "destination": "/forms-rental-application.html" },
    { "source": "/forms/lease-termination", "destination": "/forms-lease-termination.html" },
    { "source": "/forms/roommate-agreement", "destination": "/forms-roommate-agreement.html" },
    { "source": "/forms/vehicle-bill-of-sale", "destination": "/forms-vehicle-bill-of-sale.html" },
    { "source": "/forms/bill-of-sale", "destination": "/forms-bill-of-sale.html" },
    { "source": "/forms/promissory-note", "destination": "/forms-promissory-note.html" },
    { "source": "/forms/loan-agreement", "destination": "/forms-loan-agreement.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" }
      ]
    },
    {
      "source": "/sitemap.xml",
      "headers": [
        { "key": "Content-Type", "value": "application/xml" }
      ]
    }
  ]
}
